{
  "expo": {
    "name": "Fries",
    "slug": "Fries-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Fries-app-icon.png",
    "scheme": "Friesmobile",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.Fries-mobile"
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/Fries-app-icon.png",
        "monochromeImage": "./assets/images/Fries-app-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Friesmobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-localization",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "83188442-dfc1-4117-874e-e714997e11ad"
      }
    },
    "owner": "aebopi"
  }
}
