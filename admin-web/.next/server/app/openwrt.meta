{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/openwrt/layout,_N_T_/openwrt/page,_N_T_/openwrt"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/openwrt/__PAGE__",
    "/openwrt",
    "/_index",
    "/_head"
  ]
}